# Network Lab Environment Variables
# Copy this file to .env and customize as needed
# Example: cp .env.example .env

# ============================================
# PROJECT SETTINGS
# ============================================
COMPOSE_PROJECT_NAME=study-network

# ============================================
# NETWORK CONFIGURATION
# ============================================
# DMZ Network (10.0.1.0/24)
DMZ_SUBNET=10.0.1.0/24
DMZ_GATEWAY=10.0.1.1

# Internal Network (10.0.2.0/24)
INTERNAL_SUBNET=10.0.2.0/24
INTERNAL_GATEWAY=10.0.2.1

# Public Network (10.0.3.0/24)
PUBLIC_SUBNET=10.0.3.0/24
PUBLIC_GATEWAY=10.0.3.1

# ============================================
# SERVICE IP ADDRESSES
# ============================================
# Router (multi-homed)
ROUTER_IP_DMZ=10.0.1.254
ROUTER_IP_INTERNAL=10.0.2.254
ROUTER_IP_PUBLIC=10.0.3.254

# DNS Server
DNS_IP=10.0.2.10

# DHCP Server
DHCP_IP=10.0.2.11

# Web Servers
WEB1_IP=10.0.1.10
WEB2_IP=10.0.1.11
WEB3_IP=10.0.1.12

# HAProxy Load Balancer (multi-homed)
HAPROXY_IP_PUBLIC=10.0.3.10
HAPROXY_IP_DMZ=10.0.1.20

# Prometheus Instances
PROMETHEUS_INTERNAL_IP=10.0.2.19
PROMETHEUS_DMZ_IP=10.0.1.19
PROMETHEUS_PUBLIC_IP=10.0.3.19

# Grafana (multi-homed)
GRAFANA_IP_INTERNAL=10.0.2.21
GRAFANA_IP_DMZ=10.0.1.21
GRAFANA_IP_PUBLIC=10.0.3.21

# K6 Load Testing (multi-homed)
K6_IP_INTERNAL=10.0.2.30
K6_IP_DMZ=10.0.1.30

# ============================================
# HOST PORT MAPPINGS
# ============================================
# HAProxy
HAPROXY_HTTP_PORT=8080
HAPROXY_HTTPS_PORT=8443
HAPROXY_STATS_PORT=8404

# Prometheus
PROMETHEUS_INTERNAL_PORT=9090
PROMETHEUS_DMZ_PORT=9091
PROMETHEUS_PUBLIC_PORT=9092

# Grafana
GRAFANA_PORT=3000

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Grafana Admin Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus Data Retention
PROMETHEUS_RETENTION=15d

# ============================================
# IMAGE VERSIONS
# ============================================
# Pin versions for reproducibility in production
# Use 'latest' for development
PROMETHEUS_VERSION=latest
GRAFANA_VERSION=latest

# ============================================
# RESOURCE LIMITS
# ============================================
# Uncomment and customize if you need different limits
# ROUTER_CPU_LIMIT=0.5
# ROUTER_MEM_LIMIT=256M
# WEB_CPU_LIMIT=0.5
# WEB_MEM_LIMIT=256M
# HAPROXY_CPU_LIMIT=0.5
# HAPROXY_MEM_LIMIT=256M
# PROMETHEUS_CPU_LIMIT=1
# PROMETHEUS_MEM_LIMIT=1024M
# GRAFANA_CPU_LIMIT=1
# GRAFANA_MEM_LIMIT=512M

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# Set to 'true' to enable debug logging
DEBUG=false

# Set to 'true' to disable healthchecks (faster startup in dev)
DISABLE_HEALTHCHECKS=false
